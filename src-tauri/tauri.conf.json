{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LazySwitch",
  "version": "0.1.1",
  "identifier": "com.local.lazyswitch",
  "mainBinaryName": "lazyswitch",
  "build": {
    "frontendDist": "../src/renderer",
    "beforeBuildCommand": {
      "script": "cargo build --release --bin lazyswitch-cli && copy /Y target\\release\\lazyswitch-cli.exe binaries\\lazyswitch-cli.exe",
      "cwd": "."
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "createUpdaterArtifacts": true,
    "resources": {
      "binaries/lazyswitch-cli.exe": "lazyswitch-cli.exe"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "nsis/installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFBRTZBNUVFNTA5OEQ0QzAKUldUQTFKaFE3cVhtcWd6d1NQeEJDU2FYRjF1bVRNazd6OGJZSmQ2WDN0OWMrSlMwMkFXdWczYU8K",
      "endpoints": [
        "https://github.com/datell1357/LazySwitch/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
